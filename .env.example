# Oracle RMS connection
ORACLE_URL=https://your-oracle-rms-url.example.com
ORACLE_USERNAME=your_username
ORACLE_PASSWORD=your_password

# Timing (seconds)
LOGIN_WAIT_SECONDS=120
ADF_SYNC_TIMEOUT=30
PAGE_LOAD_TIMEOUT=60
ELEMENT_WAIT_TIMEOUT=20
RETRY_WAIT_SECONDS=5
MAX_RETRIES=2

# File paths
EXCEL_INPUT_FILE=data/wac_update.xlsx
LOG_DIR=logs
